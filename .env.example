PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# yt-dlp binary path (leave empty to use system default)
YTDLP_PATH=

# Temp directory for video processing
TEMP_DIR=./tmp
# Caching (Redis/Memory)
CACHE_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# Proxy Rotation (Critical for 30M hits to avoid platform bans)
# Pass an array of proxies (e.g. http://user:pass@host:port)
PROXY_LIST=
ROTATE_PROXIES=false

# System scaling
MAX_CONCURRENT_CHUNKS=4
MAX_DOWNLOAD_TIMEOUT_MS=120000
